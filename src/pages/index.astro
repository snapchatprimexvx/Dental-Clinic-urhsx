---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Stats from '../components/Stats.astro';
import AboutDoctor from '../components/AboutDoctor.astro';
import Services from '../components/Services.astro';
import Gallery from '../components/Gallery.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
	title="Dental Clinic World Dental Clinic | Modern, Trusted Dental Care"
	description="Experience premium, gentle, and modern dental care at Dental Clinic World Dental Clinic. Offering Teeth Cleaning, Root Canal, Dental Implants, Aligners & Orthodontics in New Delhi."
>
	<Header slot="header" />
	
	<Hero />
	<WhyChooseUs />
	<AboutDoctor />
	<Services />
	<Stats />
	<Gallery />
	<Testimonials />
	<Contact />
	<FloatingButtons />

	<Footer slot="footer" />
</Layout>

