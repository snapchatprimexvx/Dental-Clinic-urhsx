---
// Stats.astro
// Clean grid showing core trust metrics, utilizing thin hairlines and Inter typography
---

<section class="w-full bg-white py-16 border-b border-hairline">
  <div class="max-w-[1068px] mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4 divide-y md:divide-y-0 md:divide-x divide-hairline">
      <!-- Stat item 1 -->
      <div class="flex flex-col items-center text-center p-4 reveal">
        <span class="text-4xl md:text-5xl font-display font-semibold text-primary tracking-tight mb-2">15+</span>
        <span class="text-xs font-semibold text-ink uppercase tracking-wider mb-1">Years Experience</span>
        <p class="text-xs text-ink-muted-48 max-w-[180px]">Expert clinical judgment and over a decade of successful smile restorations.</p>
      </div>

      <!-- Stat item 2 -->
      <div class="flex flex-col items-center text-center p-4 pt-8 md:pt-4 reveal delay-100">
        <span class="text-4xl md:text-5xl font-display font-semibold text-primary tracking-tight mb-2">10k+</span>
        <span class="text-xs font-semibold text-ink uppercase tracking-wider mb-1">Happy Smiles</span>
        <p class="text-xs text-ink-muted-48 max-w-[180px]">Restoring function and aesthetics for patients of all age groups.</p>
      </div>

      <!-- Stat item 3 -->
      <div class="flex flex-col items-center text-center p-4 pt-8 md:pt-4 reveal delay-200">
        <div class="flex items-center gap-1 mb-2">
          <span class="text-4xl md:text-5xl font-display font-semibold text-primary tracking-tight">4.9</span>
          <svg class="w-6 h-6 text-yellow-500 fill-current" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
          </svg>
        </div>
        <span class="text-xs font-semibold text-ink uppercase tracking-wider mb-1">Google Rating</span>
        <p class="text-xs text-ink-muted-48 max-w-[180px]">Based on hundreds of verified patient reviews praising our gentle care.</p>
      </div>

      <!-- Stat item 4 -->
      <div class="flex flex-col items-center text-center p-4 pt-8 md:pt-4 reveal delay-300">
        <span class="text-4xl md:text-5xl font-display font-semibold text-primary tracking-tight mb-2">100%</span>
        <span class="text-xs font-semibold text-ink uppercase tracking-wider mb-1">Painless & Sterile</span>
        <p class="text-xs text-ink-muted-48 max-w-[180px]">Strict autoclave sterilization protocols and digital anesthesia aids.</p>
      </div>
    </div>
  </div>
</section>
