---
const items = [
  {
    title: "Increase Trust Among Patients",
    desc: "Verify our certifications, check patient testimonials, and see real treatment results directly.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
    </svg>`
  },
  {
    title: "All Services in One Place",
    desc: "Browse our complete range of services including cleanings, fillings, root canals, and implants.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
    </svg>`
  },
  {
    title: "Easy Contact (Call & WhatsApp)",
    desc: "Direct buttons to call us or send a quick WhatsApp message to get immediate responses.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>`
  }
];
---
<section id="why-choose-us" class="py-20 bg-white">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="mx-auto max-w-3xl text-center mb-16 reveal">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Why Patients Choose Us</h2>
      <p class="font-display text-3xl md:text-4xl font-bold tracking-tight text-ink">
        Comprehensive & Patient-Centric Dental Services
      </p>
      <p class="mt-4 text-base text-ink/60">
        We integrate modern technology, accessibility, and professional dental expertise to give you the ultimate oral healthcare experience.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-4xl mx-auto">
      {items.map((item, idx) => (
        <div class="reveal relative bg-white border border-hairline p-8 rounded-lg shadow-soft hover:shadow-product hover:-translate-y-1 transition-all duration-300 group">
          <!-- Icon Circle -->
          <div class="inline-flex items-center justify-center p-3 rounded-full bg-primary/10 text-primary mb-6 transition-transform duration-300 group-hover:scale-110">
            <Fragment set:html={item.icon} />
          </div>
          <!-- Title -->
          <h3 class="text-lg font-bold text-ink mb-3 group-hover:text-primary transition-colors">
            {item.title}
          </h3>
          <!-- Description -->
          <p class="text-sm leading-relaxed text-ink/65">
            {item.desc}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
