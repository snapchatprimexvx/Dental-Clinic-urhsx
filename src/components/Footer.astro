---
---
<footer class="bg-canvas-parchment border-t border-hairline/80 pt-16 pb-8 text-ink-muted-80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-12 pb-12 border-b border-hairline">
      
      <!-- Clinic Brand / Info -->
      <div class="lg:col-span-4 space-y-4">
        <a href="#top" class="flex items-center space-x-2 group">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-primary group-hover:scale-105 transition-transform duration-200">
            <path d="M12 2C8.5 2 6 4.5 6 8c0 4.5 3 6.5 5.5 8.5C14 18.5 14.5 20 12 22c5-1 8-4.5 8-8.5C20 9.5 17.5 8 15 6.5 12.5 5 12.5 2 12 2Z"/>
          </svg>
          <span class="font-display font-semibold tracking-tight text-lg text-ink">
            Apex<span class="text-primary font-normal">Dental</span>
          </span>
        </a>
        <p class="text-xs sm:text-sm text-ink/70 leading-relaxed max-w-sm">
          Apex Dental is dedicated to offering gentle, painless, and premium dental treatments. We prioritize patient sanitization, safety, and oral healthcare excellence above all.
        </p>
        
        <!-- Social Icons -->
        <div class="flex items-center space-x-3 pt-2">
          <!-- Facebook -->
          <a href="#" class="w-8 h-8 rounded-full bg-white border border-hairline hover:border-primary hover:text-primary transition-colors flex items-center justify-center text-ink/75" aria-label="Facebook">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
              <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="#" class="w-8 h-8 rounded-full bg-white border border-hairline hover:border-primary hover:text-primary transition-colors flex items-center justify-center text-ink/75" aria-label="Instagram">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <!-- Twitter/X -->
          <a href="#" class="w-8 h-8 rounded-full bg-white border border-hairline hover:border-primary hover:text-primary transition-colors flex items-center justify-center text-ink/75" aria-label="Twitter X">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="#" class="w-8 h-8 rounded-full bg-white border border-hairline hover:border-primary hover:text-primary transition-colors flex items-center justify-center text-ink/75" aria-label="LinkedIn">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="lg:col-span-2 space-y-4">
        <h4 class="text-xs font-bold uppercase tracking-wider text-ink">Quick Links</h4>
        <ul class="space-y-2 text-xs sm:text-sm">
          <li><a href="#why-choose-us" class="hover:text-primary transition-colors">Why Choose Us</a></li>
          <li><a href="#doctor" class="hover:text-primary transition-colors">About Doctor</a></li>
          <li><a href="#services" class="hover:text-primary transition-colors">Dental Services</a></li>
          <li><a href="#gallery" class="hover:text-primary transition-colors">Clinic Gallery</a></li>
          <li><a href="#testimonials" class="hover:text-primary transition-colors">Testimonials</a></li>
          <li><a href="#contact" class="hover:text-primary transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Column 3: Services -->
      <div class="lg:col-span-3 space-y-4">
        <h4 class="text-xs font-bold uppercase tracking-wider text-ink">Treatments</h4>
        <ul class="space-y-2 text-xs sm:text-sm">
          <li><a href="#services" class="hover:text-primary transition-colors">Teeth Cleaning & Polish</a></li>
          <li><a href="#services" class="hover:text-primary transition-colors">Root Canal Treatment</a></li>
          <li><a href="#services" class="hover:text-primary transition-colors">Dental Implants Surgery</a></li>
          <li><a href="#services" class="hover:text-primary transition-colors">Braces & Clear Aligners</a></li>
          <li><a href="#services" class="hover:text-primary transition-colors">Teeth Whitening Systems</a></li>
          <li><a href="#services" class="hover:text-primary transition-colors">Kids Pediatric Care</a></li>
        </ul>
      </div>

      <!-- Column 4: Contact details -->
      <div class="lg:col-span-3 space-y-4">
        <h4 class="text-xs font-bold uppercase tracking-wider text-ink">Contact Details</h4>
        <div class="space-y-2 text-xs sm:text-sm text-ink/75">
          <p>
            <span class="font-semibold text-ink">Address:</span> 12, Connaught Circus, Block E, CP, New Delhi, Delhi 110001
          </p>
          <p>
            <span class="font-semibold text-ink">Phone:</span> <a href="tel:+919876543210" class="hover:text-primary transition-colors">+91 98765 43210</a>
          </p>
          <p>
            <span class="font-semibold text-ink">Email:</span> <a href="mailto:info@apexdental.com" class="hover:text-primary transition-colors">info@apexdental.com</a>
          </p>
        </div>
      </div>

    </div>

    <!-- Bottom copyright row -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 text-xs text-ink/50 space-y-4 sm:space-y-0">
      <p>© {new Date().getFullYear()} Apex Dental Clinic. All Rights Reserved.</p>
      <div class="flex space-x-4">
        <a href="#" class="hover:underline hover:text-primary transition-colors">Privacy Policy</a>
        <a href="#" class="hover:underline hover:text-primary transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
