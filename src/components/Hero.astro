---
// Hero.astro
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-dentist-device.png';
---

<section class="relative w-full bg-canvas-parchment pt-16 pb-12 overflow-hidden flex flex-col items-center">
  <div class="max-w-[980px] w-full px-6 flex flex-col items-center text-center reveal active">
    <!-- Supertitle -->
    <span class="text-xs font-semibold text-primary uppercase tracking-widest mb-3">Welcome to Dental Clinic World</span>
    
    <!-- Headline: SF Pro Display 56px, negative tracking, line-height 1.07 -->
    <h1 class="font-display font-semibold text-4xl sm:text-5xl md:text-6xl text-ink leading-[1.07] tracking-[-0.03em] max-w-[800px] mb-6">
      Precision clinical care. <br class="hidden sm:inline" />
      <span class="text-primary">Beautiful, lasting smiles.</span>
    </h1>
    
    <!-- Tagline: SF Pro Display 24px/300 weight or 28px/400 weight -->
    <p class="font-sans font-normal text-lg sm:text-xl text-ink/75 max-w-[620px] leading-[1.47] tracking-[-0.02em] mb-8">
      Experience painless dental treatments with next-gen sterile technology. Dr. Harish Mansuri and our elite team restore your confidence with absolute transparency.
    </p>

    <!-- CTAs: Two pill CTAs (Primary blue, Secondary ghost) -->
    <div class="flex flex-col sm:flex-row gap-4 mb-14">
      <a href="tel:+917808255364" class="inline-flex items-center justify-center text-[15px] font-semibold px-7 py-3 text-white bg-primary hover:bg-primary-focus rounded-full shadow-sm active-scale tracking-tight">
        Call +91 78082 55364
      </a>
      <a href="#services" class="inline-flex items-center justify-center text-[15px] font-semibold px-7 py-3 text-primary bg-transparent hover:bg-primary/5 border border-primary rounded-full active-scale tracking-tight">
        Explore Services
      </a>
    </div>
  </div>

  <!-- Hero Visual: Photographic image resting on the parchment background with a soft drop shadow -->
  <div class="w-full max-w-[1100px] px-6 flex justify-center relative reveal active delay-200">
    <div class="relative w-full max-w-[850px] aspect-[16/9] flex items-center justify-center">
      <!-- Signature Drop Shadow for product image resting on the surface -->
      <Image 
        src={heroImage} 
        alt="Advanced Dental Diagnostic Tools and Precision Tooth Care Equipment" 
        class="w-full h-auto object-contain rounded-lg filter drop-shadow-[0_20px_35px_rgba(0,0,0,0.12)] border border-neutral-200/20"
        loading="eager"
      />
    </div>
  </div>
</section>
