---
const reviews = [
  {
    name: "Sarah Jenkins",
    role: "Local Patient",
    img: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=150&h=150&q=80",
    rating: 5,
    text: "I had an amazing experience at Apex Dental. Dr. Rohan and his staff were so gentle during my root canal. I felt absolutely zero pain. Highly recommended for nervous patients!"
  },
  {
    name: "Michael Chen",
    role: "Tech Consultant",
    img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=150&h=150&q=80",
    rating: 5,
    text: "The clinic is incredibly clean and modern. I went for scaling and teeth whitening, and the results are stunning. Dr. Rohan explains everything clearly and takes his time."
  },
  {
    name: "Priya Sharma",
    role: "Parent",
    img: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=150&h=150&q=80",
    rating: 5,
    text: "Extremely kid-friendly clinic! My 7-year-old was terrified of dentists, but the gentle care and friendly explanation of sealants made him smile throughout. Excellent care!"
  }
];
---
<section id="testimonials" class="py-20 bg-white">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="mx-auto max-w-3xl text-center mb-16 reveal">
      <span class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Happy Patients</span>
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-ink">
        Patient Testimonials
      </h2>
      <p class="mt-4 text-base text-ink/60">
        Read reviews from our lovely patients who have experienced our professional dental treatments.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((rev, idx) => (
        <div class="reveal bg-white border border-hairline p-8 rounded-lg shadow-soft hover:shadow-product transition-all duration-300 flex flex-col justify-between">
          <div>
            <!-- Stars -->
            <div class="flex items-center gap-1 text-amber-500 mb-6">
              {Array.from({ length: rev.rating }).map((_, i) => (
                <svg class="h-5 w-5 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            
            <!-- Testimonial text -->
            <p class="text-sm italic leading-relaxed text-ink/75 mb-8">
              "{rev.text}"
            </p>
          </div>

          <!-- User Profile -->
          <div class="flex items-center gap-4 border-t border-hairline pt-6">
            <img 
              src={rev.img} 
              alt={rev.name} 
              class="h-12 w-12 rounded-full object-cover border border-hairline"
              loading="lazy"
            />
            <div>
              <h4 class="text-sm font-bold text-ink">{rev.name}</h4>
              <p class="text-xs text-ink/50 mt-0.5">{rev.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
